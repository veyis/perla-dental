# AI provider
ANTHROPIC_API_KEY=

# Voice — ElevenLabs handles STT (Scribe v2), TTS (Flash v2.5), and the
# full-duplex phone-call agent (Conversational AI / Agents).
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
# Public agent ID from the ElevenLabs dashboard — exposed to the browser to
# let the Conversation SDK connect via WebSocket. Configure the agent's
# Custom LLM base URL = https://<your-domain>/api/voice-llm
# (ElevenLabs auto-appends /chat/completions; the route lives at
#  src/app/api/voice-llm/chat/completions/route.ts)
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=
# Shared secret for the ElevenLabs post-call webhook (workspace settings →
# Webhooks → Post-call Transcription). Receiver: /api/elevenlabs/post-call
ELEVENLABS_WEBHOOK_SECRET=
# Optional Deepgram fallback for STT — only set if you flip to lib/voice/stt-deepgram.ts
# DEEPGRAM_API_KEY=

# Supabase (project: stoxpulse, ref: zgqzsypxtcygdqnflatp, region: us-west-2)
SUPABASE_URL=https://zgqzsypxtcygdqnflatp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://zgqzsypxtcygdqnflatp.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_6KO70TMuuXPRXCTtQWZxwA_DhiDS02h

# Email
RESEND_API_KEY=
LEAD_NOTIFICATION_EMAIL=
LEAD_FROM_EMAIL=

# Operational
LEAD_FORGET_TOKEN=                       # bearer token (min 16 chars) for /api/lead/forget
LEAD_HMAC_SECRET=                        # 32+ chars; signs chat-proposed lead fields. Generate: openssl rand -hex 32
AGENT_DISABLED=false
LOG_LEVEL=info
NEXT_PUBLIC_SITE_URL=http://localhost:3000
