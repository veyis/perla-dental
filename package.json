    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.5",
    "babel-plugin-react-compiler": "^1.0.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.5",
    "playwright": "^1.59.1",
    "promptfoo": "^0.121.11",
    "tailwindcss": "^4",
