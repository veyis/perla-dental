    "@supabase/supabase-js": "^2.105.4",
    "ai": "^6.0.177",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "franc-min": "^6.2.0",
    "libphonenumber-js": "^1.13.0",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "next-intl": "^4.11.1",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "resend": "^6.12.3",
